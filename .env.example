# Copy this file to .env and fill in local values.
# Never commit .env or paste token values into chat.

# Phase 1 standalone mode requires a valid Dida365/TickTick MCP access token.
# Fill this value locally in your own .env file. Leave it blank in the repository.
DIDA365_MCP_ACCESS_TOKEN=

# Optional overrides. Defaults are usually fine.
# DIDA365_MCP_URL=https://mcp.dida365.com
# DIDA365_MCP_SERVER=dida365
# DIDA365_MCP_TOKEN_FILE=/absolute/path/to/token.json
